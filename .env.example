# Service URLs (use localhost for local dev, container names for Docker)
ORCASLICER_URL=http://localhost:8000
SPOOLMAN_URL=http://localhost:7912

# Bambu printer (optional — leave empty to skip MQTT commands)
PRINTER_IP=
PRINTER_ACCESS_CODE=
PRINTER_SERIAL=

# Optional: route activations through bambu-gateway over HTTP instead of opening
# our own MQTT slot. Use this when bambu-gateway is already running against the
# same printer (Bambu's broker only allows one client). PRINTER_SERIAL is still
# required to identify the printer to the gateway. PRINTER_IP and
# PRINTER_ACCESS_CODE can be left empty in this mode — the gateway owns the
# MQTT credentials.
BAMBU_GATEWAY_URL=

# Machine profile for filtering (default: A1 mini)
DEFAULT_MACHINE_PROFILE_ID=GM020

PORT=9817
DETAIL_FETCH_CONCURRENCY=10
